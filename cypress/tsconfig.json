{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2018",
        "lib": [
            "ES2018"
        ],
        "types": [
            "cypress"
        ],
        "noEmit": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}